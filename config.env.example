# agent-push config. Copy to ~/.config/agent-notify/config.env and `chmod 600` it.
# Repeat on every machine that runs an agent (laptop + each server). Never commit.
#
# Set the backend(s) for the phone(s) you have. Set BOTH to notify iOS + Android.

# ---- iOS / macOS: Bark (recommended, supports end-to-end encryption) ----
# Bark app -> copy the URL shown at the top.
BARK_URL="https://api.day.app/YOUR_DEVICE_KEY"
# End-to-end encryption (recommended). Set the SAME key in the Bark app under
# Settings -> Encryption (AES256 / CBC). 16, 24, or 32 chars. Empty = plaintext.
BARK_KEY=""

# ---- Android / cross-platform: ntfy (NO end-to-end encryption) ----
# Install ntfy, subscribe to an UNGUESSABLE topic, put the full topic URL here.
# For privacy use a random topic name or self-host ntfy (ntfy.sh operator can read
# plaintext topics). Leave empty if you don't use Android.
NTFY_URL=""              # e.g. https://ntfy.sh/agent-push-9f3k2xQ7pLw
NTFY_TOKEN=""            # optional: bearer token if your ntfy server requires auth

# ---- Optional: crisper custom icons (any public PNG URL) ----
# ICON_CODEX="https://.../openai.png"
# ICON_CLAUDE="https://.../claude.png"
